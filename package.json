{
  "name": "monetarist",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "analyze": "cross-env ANALYZE=true next build",
    "analyze:server": "cross-env BUNDLE_ANALYZE=server next build",
    "analyze:browser": "cross-env BUNDLE_ANALYZE=browser next build",
    "locale:extract": "cross-env NODE_ENV=development lingui extract",
    "locale:compile": "lingui compile",
    "mikro-orm": "dotenv -e .env.development.local -- npx mikro-orm",
    "mikro-orm:dev": "dotenv -e .env.development.local -- npx mikro-orm",
    "mikro-orm:staging": "dotenv -e .env.staging.local -- npx mikro-orm",
    "mikro-orm:prod": "dotenv -e .env.production.local -- npx mikro-orm",
    "update-game-data": "dotenv -e .env.development.local -- ts-node update-game-data.ts",
    "update-game-data:dev": "dotenv -e .env.development.local -- ts-node update-game-data.ts",
    "update-game-data:staging": "dotenv -e .env.staging.local -- ts-node update-game-data.ts",
    "update-game-data:prod": "dotenv -e .env.production.local -- ts-node update-game-data.ts"
  },
  "mikro-orm": {
    "useTsNode": true,
    "configPaths": [
      "./mikro-orm.config.js"
    ]
  },
  "dependencies": {
    "@chakra-ui/icons": "^2.0.4",
    "@chakra-ui/modal": "^2.1.2",
    "@chakra-ui/react": "^2.2.4",
    "@emotion/react": "^11.9.3",
    "@emotion/styled": "^11.9.3",
    "@lingui/macro": "^3.14.0",
    "@lingui/react": "^3.14.0",
    "@mikro-orm/core": "^5.3.0",
    "@mikro-orm/mariadb": "^5.3.0",
    "@mikro-orm/migrations": "^5.3.0",
    "@next/bundle-analyzer": "^12.2.2",
    "@tanstack/react-table": "^8.3.0",
    "@thewakingsands/axis-font-icons": "^0.3.0",
    "@xivapi/js": "^0.4.1",
    "cross-env": "^7.0.3",
    "framer-motion": "^6.5.1",
    "iron-session": "^6.1.3",
    "next": "^12.2.2",
    "next-csrf": "^0.2.1",
    "react": "18.2.0",
    "react-cookie": "^4.1.1",
    "react-dom": "18.2.0",
    "react-hook-form": "^7.33.1",
    "react-number-format": "^4.9.3",
    "s-ago": "^2.2.0",
    "swr": "^1.3.0",
    "timezones-list": "^3.0.1"
  },
  "devDependencies": {
    "@lingui/cli": "^3.14.0",
    "@mikro-orm/cli": "^5.3.0",
    "@types/node": "^18.0.4",
    "@types/react": "^18.0.15",
    "@types/react-dom": "^18.0.6",
    "@types/yargs": "^17.0.10",
    "eslint": "^8.19.0",
    "eslint-config-next": "^12.2.2",
    "eslint-config-prettier": "^8.5.0",
    "sass": "^1.5.1",
    "ts-node": "^10.9.1",
    "typescript": "4.7.4",
    "yargs": "^17.5.1"
  }
}
